{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug main.exe",
            "type": "cppdbg",
            "request": "launch",

            "program": "${workspaceFolder}/app.exe",
            "args": [],
            "stopAtEntry": false,

            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true,

            "MIMode": "gdb",
            "miDebuggerPath": "C:/mingw-64/mingw64/bin/gdb.exe",

            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],

            "preLaunchTask": "build debug"
        }
    ]
}
